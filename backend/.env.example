# Banco de dados (local)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=devfood
DATABASE_PASSWORD=devfood123
DATABASE_NAME=devfood_db

# Em produção (Render), use DATABASE_URL no lugar das variáveis acima
# DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT
JWT_SECRET=change-in-production
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=development

# CORS — separado por vírgula se mais de uma origem (produção: URL do Vercel)
FRONTEND_URL=http://localhost:3000

# Sincronização automática do banco (true = cria/atualiza tabelas)
# Mantenha "true" no primeiro deploy; troque para "false" depois
DB_SYNCHRONIZE=true
